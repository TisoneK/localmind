# LocalMind Configuration
# Copy this file to .env and edit as needed
# Never commit .env to version control

# ── Ollama ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120

# ── Adapter ─────────────────────────────────────────────
# Options: ollama | lmstudio (future) | llamacpp (future)
LOCALMIND_ADAPTER=ollama

# ── Server ──────────────────────────────────────────────
LOCALMIND_HOST=127.0.0.1
LOCALMIND_PORT=8000
LOCALMIND_LOG_LEVEL=INFO

# ── Storage ─────────────────────────────────────────────
LOCALMIND_DB_PATH=./localmind.db
LOCALMIND_CHROMA_PATH=./chroma_db

# ── Tools ───────────────────────────────────────────────
# File reader
LOCALMIND_MAX_FILE_SIZE_MB=50
LOCALMIND_CHUNK_SIZE_TOKENS=1500
LOCALMIND_CHUNK_OVERLAP_TOKENS=200

# Web search
# Options: duckduckgo (no key needed) | brave (requires key)
LOCALMIND_SEARCH_PROVIDER=duckduckgo
BRAVE_SEARCH_API_KEY=

# Code executor
LOCALMIND_CODE_EXEC_TIMEOUT=30
LOCALMIND_CODE_EXEC_ENABLED=true

# ── Context window ──────────────────────────────────────
# Tokens reserved for the model response
LOCALMIND_RESPONSE_RESERVE_TOKENS=2048
# Max tokens for conversation history
LOCALMIND_HISTORY_MAX_TOKENS=4096
