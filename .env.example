# ── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b             # llama3.1:8b, gemma3:1b
OLLAMA_TIMEOUT=300

# v0.2: Model routing — leave blank to use OLLAMA_MODEL for all requests
OLLAMA_MODEL_FAST=gemma3:1b          # e.g. phi3:mini  (short CHAT turns)
OLLAMA_MODEL_CODE=llama3.1:8b        # e.g. qwen2.5-coder:7b  (CODE_EXEC intent)

# ── Adapter ─────────────────────────────────────────────────────────────────
LOCALMIND_ADAPTER=ollama

# ── Server ──────────────────────────────────────────────────────────────────
LOCALMIND_HOST=127.0.0.1
LOCALMIND_PORT=8000
LOCALMIND_LOG_LEVEL=DEBUG

# ── Storage ─────────────────────────────────────────────────────────────────
LOCALMIND_HOME=~/LocalMind
LOCALMIND_DB_PATH=./localmind.db
LOCALMIND_UPLOADS_PATH=~/LocalMind/uploads

# ── File reader ─────────────────────────────────────────────────────────────
LOCALMIND_MAX_FILE_SIZE_MB=50
LOCALMIND_CHUNK_SIZE_TOKENS=1500
LOCALMIND_CHUNK_OVERLAP_TOKENS=200

# ── Web search ──────────────────────────────────────────────────────────────
LOCALMIND_SEARCH_PROVIDER=duckduckgo
BRAVE_SEARCH_API_KEY=       # Optional — for Brave Search provider

# ── Code executor ───────────────────────────────────────────────────────────
LOCALMIND_CODE_EXEC_TIMEOUT=30
LOCALMIND_CODE_EXEC_ENABLED=true

# ── Context window ──────────────────────────────────────────────────────────
LOCALMIND_RESPONSE_RESERVE_TOKENS=2048
LOCALMIND_HISTORY_MAX_TOKENS=4096

# ── Agent loop (v0.2) ───────────────────────────────────────────────────────
LOCALMIND_AGENT_ENABLED=true
LOCALMIND_AGENT_MAX_ITERATIONS=6

# ── Permissions ────────────────────────────────────────────────────────────
LOCALMIND_REQUIRE_WRITE_PERMISSION=true

# ── Shell tool (self-repair / file inspection) ──────────────────────────────
LOCALMIND_SHELL_ENABLED=true    # set to true to allow shell commands (cat, git, pip etc.)
